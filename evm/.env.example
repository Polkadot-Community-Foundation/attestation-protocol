# BIP39 mnemonic that signs the deploy. The deployer's SS58 account pays the fees
# and storage deposits, so it MUST be funded on the target network.
# ⚠️  The value below is the well-known DEV phrase — safe ONLY against a local node.
#     Replace it with a funded key before deploying to any real network.
export MNEMONIC="bottom drive obey lake curtain smoke basket hold race lonely fit walk"

# Optional. HD derivation path on the mnemonic.
# (Default: empty for a real MNEMONIC; //Alice when MNEMONIC is unset.)
# export DERIVATION_PATH=

# Target network, selected by GENESIS HASH (see evm/scripts/network.ts). Known networks:
#   paseo-v1  0xd6eec26135305a8ad257a20d003357284c8aa03d0bdb2b357ab0a22371e11ef2
#   paseo-v2  0x173cea9df45656cf612c8b8ece56e04e9a693c69cfaac47d3628dae735067af8
#   summit    0xf388dc6d6cdf6fb77eac3c4a91f31bc0c8642b142f1a757512ab7849f9f70660
# ⚠️  Set this to YOUR target. The default below is Summit; change it for other networks.
export GENESIS_HASH=0xf388dc6d6cdf6fb77eac3c4a91f31bc0c8642b142f1a757512ab7849f9f70660

# Optional. Override the RPC endpoint without editing network.ts — e.g. to point a
# rehearsal at a local Chopsticks fork. GENESIS_HASH still selects the network config.
# export RPC_URL=ws://localhost:8000
